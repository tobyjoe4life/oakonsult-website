---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Events | OAKonsult"
	description="Upcoming events and gatherings from OAKonsult."
	path="/events"
>
	<section class="section">
		<div class="container callout reveal">
			<p class="section-kicker">Events</p>
			<h1>Events</h1>
			<p>
				Learn, connect, and contribute to a more inclusive world through OAKonsult events,
				campaign gatherings, and training sessions.
			</p>
			<div class="callout-actions">
				<a class="button button-primary" href="/contact-us">Ask About Upcoming Events</a>
				<a class="button button-ghost" href="/get-involved">Get Involved</a>
			</div>
		</div>
	</section>
</Layout>

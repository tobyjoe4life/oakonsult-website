---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Partnerships | OAKonsult"
	description="Partner with OAKonsult to create lasting impact for families raising children with disabilities."
	path="/partnerships"
>
	<section class="section">
		<div class="container callout reveal">
			<p class="section-kicker">Partnerships</p>
			<h1>Partnerships</h1>
			<p>
				Join our growing network of faith groups, organisations, professionals, and funders who
				are helping OAKonsult expand inclusive support across the UK, Nigeria, and online.
			</p>
			<div class="callout-actions">
				<a class="button button-primary" href="/contact-us">Start a Partnership</a>
				<a class="button button-ghost" href="/annual-reports-impact">View Impact</a>
			</div>
		</div>
	</section>
</Layout>

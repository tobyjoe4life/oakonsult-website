---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Nigeria Programs | OAKonsult"
	description="OAKonsult programmes and initiatives currently delivered in Nigeria."
	path="/nigeria-programs"
>
	<section class="section">
		<div class="container">
			<p class="section-kicker reveal">Nigeria</p>
			<h1 class="section-title reveal" style="--delay: 0.05s">Nigeria Programs</h1>
			<p class="reveal muted-copy" style="--delay: 0.1s;">
				Our Nigeria programmes focus on disability awareness, church inclusion training, and
				sustainable services through OAK Centre Prime.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container card-grid">
			<article class="card reveal">
				<h2>OAK Centre Prime</h2>
				<p>
					A purpose-built disability support centre in Ogbomoso offering therapy, education,
					residential care, and vocational pathways.
				</p>
				<a class="inline-link" href="/oak-centre-prime">Read More</a>
			</article>
			<article class="card reveal" style="--delay: 0.08s">
				<h2>Support for Churches</h2>
				<p>
					Inclusive training for churches and faith communities to welcome and disciple families
					of every ability.
				</p>
				<a class="inline-link" href="/support-for-churches">Read More</a>
			</article>
		</div>
	</section>
</Layout>

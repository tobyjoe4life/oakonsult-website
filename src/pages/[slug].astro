---
import Layout from "../layouts/Layout.astro";
import { governanceTeam } from "../data/site";

export function getStaticPaths() {
	return governanceTeam.map((member) => ({
		params: { slug: member.slug },
		props: { member },
	}));
}

const { member } = Astro.props;
---

<Layout
	title={`${member.name} | OAKonsult`}
	description={`${member.name} serves as ${member.role} at OAKonsult Disabilities Outreach.`}
	path={`/${member.slug}`}
>
	<section class="hero">
		<div class="container hero-grid">
			<div class="reveal" style="--delay: 0.05s">
				<p class="section-kicker">Team Profile</p>
				<h1>{member.name}</h1>
				<p style="margin-top: 0.5rem; font-size: var(--text-lead); color: var(--oak-teal); font-weight: 600;">
					{member.role}
				</p>
				<p style="margin-top: 1rem; color: var(--oak-muted); max-width: 52ch; line-height: 1.75;">
					{member.profile}
				</p>
				<div class="hero-actions">
					<a class="button button-primary" href="/our-team">Back to Team</a>
					<a class="button button-ghost" href="/contact-us">Contact Us</a>
				</div>
			</div>
			<div class="hero-media reveal" style="--delay: 0.1s">
				<img
					src={member.image}
					alt={member.name}
					style="aspect-ratio: 4/5; object-fit: cover;"
				/>
			</div>
		</div>
	</section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="UK Programs | OAKonsult"
	description="OAKonsult programmes currently delivered for families and carers in the United Kingdom."
	path="/uk-programs"
>
	<section class="section">
		<div class="container">
			<p class="section-kicker reveal">United Kingdom</p>
			<h1 class="section-title reveal" style="--delay: 0.05s">UK Programs</h1>
			<p class="reveal muted-copy" style="--delay: 0.1s;">
				Our UK delivery supports parent carers with wellbeing training, peer community, and
				inclusive pathways that help families thrive.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container card-grid">
			<article class="card reveal">
				<h2>Project ME</h2>
				<p>
					Holistic workshops, practical sessions, and therapeutic content designed for parent
					carers in Bromley and surrounding communities.
				</p>
				<a class="inline-link" href="/projectme">Read More</a>
			</article>
			<article class="card reveal" style="--delay: 0.08s">
				<h2>Support for Parent Carers</h2>
				<p>
					One-to-one coaching, wellbeing support, peer circles, and signposting to vital local
					services.
				</p>
				<a class="inline-link" href="/support-for-parent-carers">Read More</a>
			</article>
		</div>
	</section>
</Layout>

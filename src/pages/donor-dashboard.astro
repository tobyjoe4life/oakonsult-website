---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Donor Dashboard | OAKonsult"
	description="Donor account services are being migrated."
	path="/donor-dashboard"
>
	<section class="section">
		<div class="container callout reveal">
			<p class="section-kicker">Donor Dashboard</p>
			<h1>Dashboard access is being migrated</h1>
			<p>
				We are moving donor account services to a new CRM workflow. For receipts, recurring gift
				updates, or account support, please contact us directly.
			</p>
			<div class="callout-actions">
				<a class="button button-primary" href="/contact-us">Contact Support</a>
				<a class="button button-ghost" href="/donate">Donate</a>
			</div>
		</div>
	</section>
</Layout>

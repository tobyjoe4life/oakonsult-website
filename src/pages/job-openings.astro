---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Jobs | OAKonsult"
	description="Join OAKonsult and help build programmes, content, and community that change lives."
	path="/job-openings"
>
	<section class="section">
		<div class="container callout reveal">
			<p class="section-kicker">Jobs</p>
			<h1>Join OAKonsult - Include Every Ability</h1>
			<p>Build programmes, content, and community that change lives.</p>
			<div class="callout-actions">
				<a class="button button-primary" href="#jobs">View Current Openings</a>
			</div>
		</div>
	</section>

	<section id="jobs" class="section">
		<div class="container card reveal">
			<h2>No Open Roles Right Now</h2>
			<p style="margin-top: 0.7rem;">
				We currently have no job openings. You can still send your interest and CV to
				<a href="mailto:info@oakonsult.org">info@oakonsult.org</a> for future opportunities.
			</p>
		</div>
	</section>
</Layout>

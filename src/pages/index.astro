---
import Layout from "../layouts/Layout.astro";
import {
	campaignPreviews,
	contact,
	donationCta,
	featuredPosts,
	impactTimeline,
	partnerGroups,
	programs,
	testimonials,
} from "../data/site";
---

<Layout
	title="OAKonsult | Living Life Abundantly"
	description="Empowering special needs families to live abundantly through practical support, inclusive training, and community-led outreach."
	path="/"
>
	<!-- Hero -->
	<section class="hero">
		<div class="container hero-grid">
			<div class="reveal" style="--delay: 0.05s">
				<p class="section-kicker">UK Registered Charity No. {contact.charityNumber}</p>
				<h1>Empowering Special Needs Families to Live Abundantly</h1>
				<p>
					We walk alongside families raising children with disabilities, offering care,
					community, and courage to thrive &mdash; not just survive.
				</p>
				<div class="hero-actions">
					<a class="button button-primary" href={donationCta.href}>Donate Now</a>
					<a class="button button-ghost" href="#our-story">Watch Our Story</a>
				</div>
			</div>
			<div class="hero-media reveal" style="--delay: 0.12s">
				<img src="/media/wp/2022/09/oak-images-9.png" alt="Disability inclusion - supporting children and families together" />
			</div>
		</div>
	</section>

	<!-- Impact Stats Bar -->
	<section class="stats-bar">
		<div class="container">
			<div class="stat-item reveal" style="--delay: 0.05s">
				<strong>5+</strong>
				<span>Core Programmes</span>
			</div>
			<div class="stat-item reveal" style="--delay: 0.1s">
				<strong>2</strong>
				<span>Countries (UK &amp; Nigeria)</span>
			</div>
			<div class="stat-item reveal" style="--delay: 0.15s">
				<strong>1,000+</strong>
				<span>Families Reached</span>
			</div>
			<div class="stat-item reveal" style="--delay: 0.2s">
				<strong>2021</strong>
				<span>Founded</span>
			</div>
		</div>
	</section>

	<!-- Core Programs -->
	<section class="section">
		<div class="container">
			<div class="section-header">
				<p class="section-kicker reveal">What We Do</p>
				<h2 class="section-title reveal" style="--delay: 0.05s">Our Programmes &amp; Services</h2>
			</div>
			<div class="card-grid">
				{
					programs.map((program, i) => (
						<article class="card reveal" style={`--delay: ${0.08 + i * 0.06}s`}>
							<img
								src={program.image}
								alt={program.title}
								style="border-radius: var(--radius); aspect-ratio: 16/10; object-fit: cover; margin-bottom: 1rem;"
								loading="lazy"
							/>
							<h3>{program.title}</h3>
							<p>{program.summary}</p>
							<a class="inline-link" href={`/${program.slug}`}>Learn more &rarr;</a>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<!-- Our Story + Video -->
	<section class="section section-alt" id="our-story">
		<div class="container split">
			<div class="reveal">
				<p class="section-kicker">Our Story</p>
				<h2 class="section-title" style="max-width: 20ch;">From Crisis to Calling</h2>
				<p class="muted-copy" style="margin-top: 0.75rem;">
					In 2010, one family's world changed forever when a medical error led to their
					18-month-old daughter's brain injury. Abigail's courage became the foundation
					of OAKonsult &mdash; a charity born from lived experience and driven by faith,
					love, and an unwavering commitment to disability inclusion.
				</p>
				<p style="margin-top: 0.75rem; color: var(--oak-muted); line-height: 1.75;">
					While our faith shapes our ethos, OAKonsult is not faith-restrictive. If you
					love and care for a child with disabilities, you belong here.
				</p>
				<div style="margin-top: 1.5rem;">
					<a class="button button-primary" href="/about-us">About OAKonsult</a>
				</div>
			</div>
			<div class="reveal" style="--delay: 0.1s">
				<img
					src="/media/wp/2022/11/FAMILY-REPLACE-OUR-STORY-PHOTO-scaled-1.jpg"
					alt="The Adeloye family - founders of OAKonsult"
					style="border-radius: var(--radius); aspect-ratio: 4/3; object-fit: cover; margin-bottom: 1rem;"
					loading="lazy"
				/>
				<div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: var(--radius);">
					<iframe
						src="https://www.youtube.com/embed/UFT7JUt_4AI"
						title="OAKonsult Story"
						style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
						allowfullscreen
						loading="lazy"
					></iframe>
				</div>
			</div>
		</div>
	</section>

	<!-- Testimonials -->
	<section class="section">
		<div class="container">
			<div class="section-header">
				<p class="section-kicker reveal">Voices of Impact</p>
				<h2 class="section-title reveal" style="--delay: 0.05s">What Families Say</h2>
			</div>
			<div class="card-grid">
				{
					testimonials.map((t, i) => (
						<article class="card reveal" style={`--delay: ${0.08 + i * 0.06}s; border-left: 3px solid var(--oak-gold);`}>
							<blockquote style="margin: 0; font-style: italic; color: var(--oak-muted); line-height: 1.75;">
								&ldquo;{t.quote}&rdquo;
							</blockquote>
							<p style="margin-top: 0.75rem; font-weight: 600; color: var(--oak-forest);">
								{t.name}, {t.location}
							</p>
							<p style="font-size: var(--text-small); color: var(--oak-teal);">{t.context}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<!-- Campaigns / Donate -->
	<section class="section section-alt">
		<div class="container">
			<div class="section-header">
				<p class="section-kicker reveal">Support Our Work</p>
				<h2 class="section-title reveal" style="--delay: 0.05s; max-width: 26ch;">
					Your Gift Is More Than Support. It's Hope Made Real.
				</h2>
			</div>
			<div class="card-grid">
				{
					campaignPreviews.map((campaign, i) => (
						<article class="card reveal" style={`--delay: ${0.08 + i * 0.06}s`}>
							<h3>{campaign.title}</h3>
							<p>{campaign.description}</p>
							<a class="inline-link" href={campaign.href}>Learn more &rarr;</a>
						</article>
					))
				}
			</div>
			<div class="reveal" style="--delay: 0.3s; margin-top: 1.5rem; text-align: center;">
				<a class="button button-primary" href="/donate" style="font-size: 1rem; padding: 0.75rem 2rem;">
					Donate Now
				</a>
				<p style="margin-top: 0.5rem; font-size: var(--text-small); color: var(--oak-muted);">
					UK taxpayers: your donation goes 25% further with Gift Aid
				</p>
			</div>
		</div>
	</section>

	<!-- Impact Timeline -->
	<section class="section">
		<div class="container split">
			<div class="reveal">
				<p class="section-kicker">Our Journey</p>
				<h2 class="section-title" style="max-width: 20ch;">Key Milestones</h2>
				<ul class="timeline">
					{
						impactTimeline.map((item) => (
							<li>
								<span class="year">{item.year}</span>
								<p>{item.milestone}</p>
							</li>
						))
					}
				</ul>
			</div>
			<div>
				<img
					class="reveal"
					style="--delay: 0.1s"
					src="/media/wp/2022/09/oak-images-1.png"
					alt="OAKonsult community programme in action"
					loading="lazy"
				/>
			</div>
		</div>
	</section>

	<!-- Partners -->
	<section class="section section-alt">
		<div class="container">
			<div class="section-header">
				<p class="section-kicker reveal">Partners &amp; Supporters</p>
				<h2 class="section-title reveal" style="--delay: 0.05s">Working Together for Inclusion</h2>
			</div>
			<div class="partner-grid">
				{
					partnerGroups.map((partner, i) => (
						<div class="partner-card reveal" style={`--delay: ${0.08 + i * 0.04}s`}>
							<img src={partner.logo} alt={partner.name} loading="lazy" />
							<span>{partner.name}</span>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- Latest News -->
	<section class="section">
		<div class="container">
			<div class="section-header">
				<p class="section-kicker reveal">News &amp; Updates</p>
				<h2 class="section-title reveal" style="--delay: 0.05s">Latest from OAKonsult</h2>
			</div>
			<div class="card-grid">
				{
					featuredPosts.slice(0, 4).map((post, i) => (
						<article class="card reveal" style={`--delay: ${0.08 + i * 0.06}s`}>
							<p style="font-size: var(--text-small); color: var(--oak-teal); font-weight: 600; margin-bottom: 0.5rem;">{post.date}</p>
							<h3 style="font-size: 1.0625rem;">{post.title}</h3>
							<a class="inline-link" href={post.href} target="_blank" rel="noreferrer">
								Read article &rarr;
							</a>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<!-- Newsletter + CTA -->
	<section class="section section-alt">
		<div class="container">
			<div class="callout reveal" style="text-align: center;">
				<p class="section-kicker">Stay Connected</p>
				<h2>Join Our Community</h2>
				<p style="max-width: 48ch; margin: 0.5rem auto 0;">
					Get updates on our programmes, impact stories, and ways to support families
					raising children with disabilities.
				</p>
				<div class="callout-actions" style="justify-content: center;">
					<a class="button button-primary" href="/get-involved">Get Involved</a>
					<a class="button button-ghost" href="/contact-us">Contact Us</a>
				</div>
			</div>
		</div>
	</section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Fundraising | OAKonsult"
	description="Fundraise with OAKonsult to support families raising children with disabilities."
	path="/fundraising"
>
	<section class="section">
		<div class="container callout reveal">
			<p class="section-kicker">Fundraising</p>
			<h1>Fundraising</h1>
			<p>
				Plan a campaign, challenge event, or community drive that helps fund practical support,
				inclusive training, and disability inclusion programmes.
			</p>
			<div class="callout-actions">
				<a class="button button-primary" href="/contact-us">Start a Fundraiser</a>
				<a class="button button-ghost" href="/donate">Donate Instead</a>
			</div>
		</div>
	</section>
</Layout>

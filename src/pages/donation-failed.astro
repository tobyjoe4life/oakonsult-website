---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Donation Failed | OAKonsult"
	description="Your donation could not be completed. Try again or contact OAKonsult."
	path="/donation-failed"
>
	<section class="section">
		<div class="container callout reveal">
			<p class="section-kicker">Donation Update</p>
			<h1>We could not complete your donation</h1>
			<p>
				Please try again, or contact our team if you need support completing your gift through
				the current donation channel.
			</p>
			<div class="callout-actions">
				<a class="button button-primary" href="/donate">Try Again</a>
				<a class="button button-ghost" href="/contact-us">Contact Donation Team</a>
			</div>
		</div>
	</section>
</Layout>

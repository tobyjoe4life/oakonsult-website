---
import Layout from "../layouts/Layout.astro";
import { contact } from "../data/site";
---

<Layout
	title="Privacy Policy | OAKonsult"
	description="How OAKonsult Disabilities Outreach collects, uses, and protects your personal data."
	path="/privacy-policy"
>
	<section class="hero">
		<div class="container">
			<p class="section-kicker reveal">Legal</p>
			<h1 class="reveal" style="--delay: 0.05s;">Privacy Policy</h1>
			<p class="muted-copy reveal" style="--delay: 0.08s;">
				How OAKonsult Disabilities Outreach collects, uses, and protects your personal data.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container" style="max-width: 780px;">
			<div class="reveal">
				<h2 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Who We Are</h2>
				<p style="color: var(--oak-muted); line-height: 1.8; margin-bottom: 1.5rem;">
					OAKonsult Disabilities Outreach is a registered charity in England and Wales
					(Charity Registration No. {contact.charityNumber}). Our registered office is at
					{contact.ukAddress.join(", ")}. When we refer to "we", "us", or "our" in this
					policy, we mean OAKonsult Disabilities Outreach.
				</p>

				<h2 style="font-size: 1.25rem; margin-bottom: 0.5rem;">What Data We Collect</h2>
				<p style="color: var(--oak-muted); line-height: 1.8; margin-bottom: 0.5rem;">
					We may collect the following personal data when you interact with us:
				</p>
				<ul class="simple-list" style="margin-bottom: 1.5rem;">
					<li>Name, email address, and phone number when you contact us or sign up</li>
					<li>Donation information when you give to our campaigns</li>
					<li>Information you provide when registering for programmes or events</li>
					<li>Website usage data through cookies and analytics</li>
				</ul>

				<h2 style="font-size: 1.25rem; margin-bottom: 0.5rem;">How We Use Your Data</h2>
				<p style="color: var(--oak-muted); line-height: 1.8; margin-bottom: 0.5rem;">
					We use your personal data to:
				</p>
				<ul class="simple-list" style="margin-bottom: 1.5rem;">
					<li>Process donations and claim Gift Aid where applicable</li>
					<li>Deliver our programmes, training, and support services</li>
					<li>Send updates about our work (with your consent)</li>
					<li>Comply with legal and regulatory obligations</li>
				</ul>

				<h2 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Your Rights</h2>
				<p style="color: var(--oak-muted); line-height: 1.8; margin-bottom: 1.5rem;">
					Under UK GDPR, you have the right to access, correct, or delete your personal data.
					You can also withdraw consent for marketing communications at any time. To exercise
					any of these rights, please contact us at
					<a href={`mailto:${contact.email}`} style="color: var(--oak-teal);">{contact.email}</a>.
				</p>

				<h2 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Cookies</h2>
				<p style="color: var(--oak-muted); line-height: 1.8; margin-bottom: 1.5rem;">
					This website uses essential cookies to ensure proper functionality. We do not use
					advertising or tracking cookies. Analytics data is collected anonymously to help us
					improve the website experience.
				</p>

				<h2 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Contact Us</h2>
				<p style="color: var(--oak-muted); line-height: 1.8;">
					If you have any questions about this privacy policy or how we handle your data,
					please contact us at <a href={`mailto:${contact.email}`} style="color: var(--oak-teal);">{contact.email}</a>
					or write to us at {contact.ukAddress.join(", ")}.
				</p>

				<p style="margin-top: 1.5rem; font-size: var(--text-small); color: var(--oak-muted);">
					Last updated: April 2026
				</p>
			</div>
		</div>
	</section>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
---

<Layout
	title="Support for Parent Carers | OAKonsult"
	description="Because every carer's wellbeing is the bedrock of a flourishing family."
	path="/programs/support-for-parent-carers"
>
	<section class="section">
		<div class="container split">
			<div class="reveal">
				<p class="section-kicker">Program</p>
				<h1 class="section-title">Support for Parent Carers</h1>
				<p class="muted-copy" style="margin-top: 0.9rem;">
					Because every carer's wellbeing is the bedrock of a flourishing family.
				</p>
				<div class="callout-actions" style="margin-top: 1.2rem;">
					<a class="button button-primary" href="https://chat.whatsapp.com/EwrPj2uwxoX0yBgzDCacBe" target="_blank" rel="noreferrer">
						Request support
					</a>
					<a class="button button-ghost" href="/programs-services">All Services</a>
				</div>
			</div>
			<img
				class="reveal"
				style="--delay: 0.12s"
				src="/media/wp/2025/04/TVC-pictures-scaled-1.jpg"
				alt="Parent carers support"
			/>
		</div>
	</section>

	<section class="section">
		<div class="container callout reveal">
			<p>
				One-to-one coaching, wellbeing workshops and safe spaces to connect and recharge.
				While our faith shapes our ethos and inspires every programme we run, OAKonsult is not
				faith-restrictive. We stand with every parent carer of a child or young person aged
				0-25 who lives with additional needs or disabilities.
			</p>
			<p style="margin-top: 0.8rem;">
				Caring for a child with additional needs can feel overwhelming. At OAKonsult, we wrap
				you in a circle of care, combining practical tools with spiritual encouragement, so
				you can thrive, not just survive.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container card-grid">
			<article class="card reveal">
				<h2>Project ME (online or in-person)</h2>
				<p>
					Our easy-to-follow programme designed with and for parent carers, covering emotional
					wellbeing, relationships, career, finance, health, and faith.
				</p>
				<a class="inline-link" href="/projectme">Join Project ME</a>
			</article>
			<article class="card reveal" style="--delay: 0.08s">
				<h2>Parent Carer Hub (coming soon)</h2>
				<p>
					A friendly space for regular meet-ups, workshops and drop-in advice, plus peer support.
				</p>
				<a class="inline-link" href="/contact-us">Join the Hub waitlist</a>
			</article>
			<article class="card reveal" style="--delay: 0.16s">
				<h2>Peer Circles & Prayer</h2>
				<p>
					A supportive WhatsApp prayer group and periodic Zoom/in-person circles where carers can
					share, pray, and encourage one another.
				</p>
				<a class="inline-link" href="https://chat.whatsapp.com/EwrPj2uwxoX0yBgzDCacBe" target="_blank" rel="noreferrer">
					Join WhatsApp Group
				</a>
			</article>
			<article class="card reveal" style="--delay: 0.24s">
				<h2>Weekly Prayer on YouTube</h2>
				<p>Join our Prayer for Parent Carers livestream and catch up on replays anytime.</p>
				<a class="inline-link" href="https://www.youtube.com/c/ThePrayingCarerChannel" target="_blank" rel="noreferrer">
					Visit YouTube Channel
				</a>
			</article>
			<article class="card reveal" style="--delay: 0.3s">
				<h2>Practical Support & Signposting</h2>
				<p>
					Light-touch help to navigate education, health and social care forms, referrals, and
					local service pathways.
				</p>
				<a class="inline-link" href="/contact-us">Request Support</a>
			</article>
		</div>
	</section>
</Layout>

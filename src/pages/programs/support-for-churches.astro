---
import Layout from "../../layouts/Layout.astro";
---

<Layout
	title="Support for Churches | OAKonsult"
	description="Equip your church to welcome every family and disciple every member, whatever their abilities."
	path="/programs/support-for-churches"
>
	<section class="section">
		<div class="container split">
			<div class="reveal">
				<p class="section-kicker">Program</p>
				<h1 class="section-title">Support for Churches</h1>
				<p class="muted-copy" style="margin-top: 0.9rem;">
					Equip your church to welcome every family and disciple every member, whatever their
					abilities.
				</p>
				<p class="muted-copy" style="margin-top: 0.7rem;">
					We help churches become places where children, young people and adults with
					disabilities, and their parent carers, can truly belong, grow and serve.
				</p>
			</div>
			<img
				class="reveal"
				style="--delay: 0.12s"
				src="/media/wp/2025/08/AdobeStock_1105364354-scaled.jpeg"
				alt="Church inclusion support"
			/>
		</div>
	</section>

	<section class="section">
		<div class="container callout reveal">
			<h2>Turning Compassion Into Action</h2>
			<p>
				Because every church can become a place where every person belongs and flourishes. We
				equip churches to welcome and disciple people with disabilities and walk well with
				their families through practical inclusion and biblical foundations.
			</p>
			<p style="margin-top: 0.7rem;">
				While our faith shapes everything we do, OAKonsult is not faith-restrictive. We
				partner with churches of every tradition and size across the UK and Nigeria, and we
				also deliver online.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container card-grid">
			<article class="card reveal">
				<h2>Inclusive Training</h2>
				<p>
					Practical, faith-rooted training that equips leaders and volunteers to make Sundays,
					mid-week groups and events welcoming for everyone.
				</p>
				<ul class="simple-list" style="margin-top: 0.6rem;">
					<li>People-first language and a theology of dignity</li>
					<li>Inclusive worship and sensory-aware service design</li>
					<li>Children and youth participation pathways</li>
					<li>Hospitality flow, safeguarding, and signposting</li>
					<li>Delivery: 90-minute, half-day, full-day, or 3-6 week cohort</li>
				</ul>
				<a class="inline-link" href="/contact-us">Book Inclusive Training</a>
			</article>
			<article class="card reveal" style="--delay: 0.08s">
				<h2>Beyond Suffering Programme</h2>
				<p>
					A guided programme based on Beyond Suffering: A Christian View on Disability
					Ministry. Core curriculum includes theology of disability, suffering, ministry
					response, and bioethics.
				</p>
				<ul class="simple-list" style="margin-top: 0.6rem;">
					<li>Conference delivery for leaders and church teams</li>
					<li>Training for parent carers within congregations</li>
					<li>16-week curriculum or 3-week intensive for cohorts</li>
				</ul>
				<a class="inline-link" href="/contact-us">Book a Beyond Suffering Cohort</a>
			</article>
			<article class="card reveal" style="--delay: 0.16s">
				<h2>Outcomes You Can Expect</h2>
				<ul class="simple-list">
					<li>Confident volunteers with a shared language and plan</li>
					<li>More accessible services and group environments</li>
					<li>Clear signposting pathways into local support systems</li>
					<li>Stronger relationships with parent carers in your community</li>
				</ul>
			</article>
		</div>
	</section>

	<section class="section">
		<div class="container callout reveal">
			<h2>How It Works</h2>
			<ul class="simple-list" style="margin-top: 0.7rem;">
				<li>Enquire: tell us about your church and goals.</li>
				<li>Shape the plan: choose topics, format and dates for your context.</li>
				<li>Deliver and follow-up: we train teams and agree practical next steps.</li>
			</ul>
			<div class="callout-actions">
				<a class="button button-primary" href="/contact-us">Enquire / Book Training</a>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<p class="section-kicker reveal">Photos</p>
			<div class="gallery">
				<img class="reveal" src="/media/wp/2022/11/WhatsApp-Image-2022-11-19-at-12.24.21.jpeg" alt="Training photo 1" />
				<img class="reveal" style="--delay: 0.05s" src="/media/wp/2024/01/SP20-768x627.jpg" alt="Training photo 2" />
				<img class="reveal" style="--delay: 0.1s" src="/media/wp/2024/01/BF17-768x583.jpg" alt="Training photo 3" />
			</div>
		</div>
	</section>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
---

<Layout
	title="Project ME | OAKonsult"
	description="A programme that equips parent carers with holistic workshops, peer support and practical tools to thrive."
	path="/programs/projectme"
>
	<section class="section">
		<div class="container split">
			<div class="reveal">
				<p class="section-kicker">Program</p>
				<h1 class="section-title">Project ME</h1>
				<p class="muted-copy" style="margin-top: 0.9rem;">
					A programme that equips all parent carers with holistic workshops, peer support and
					practical tools to thrive.
				</p>
				<div class="callout-actions" style="margin-top: 1.2rem;">
					<a class="button button-primary" href="/contact-us">Register Your Interest</a>
					<a class="button button-ghost" href="/programs-services">All Services</a>
				</div>
			</div>
			<img
				class="reveal"
				style="--delay: 0.12s"
				src="/media/wp/2023/10/IMG-20221020-WA0023-Project-Me.jpg"
				alt="Project ME training"
			/>
		</div>
	</section>

	<section class="section">
		<div class="container card-grid">
			<article class="card reveal">
				<h2>Programme Overview</h2>
				<p>
					OAKonsult, in collaboration with Bromley Council, Your Voice in Health & Social Care,
					SEND Parenting and STUBS Disability Services, developed Project ME through Civil
					Society Roots 3 support.
				</p>
				<p style="margin-top: 0.6rem;">
					It includes workshops, training, practical sessions, focus groups and therapeutic
					content for parent carers of children and young people with additional needs and
					disabilities in Bromley.
				</p>
			</article>
			<article class="card reveal" style="--delay: 0.08s">
				<h2>What Project ME Addresses</h2>
				<ul class="simple-list">
					<li>Identity and beliefs before and after diagnosis</li>
					<li>Mental health and emotional wellbeing awareness</li>
					<li>Carer health, nutrition, rest and movement</li>
					<li>Routes into volunteering, employment and community participation</li>
					<li>Building supportive networks that last beyond the course</li>
				</ul>
			</article>
			<article class="card reveal" style="--delay: 0.16s">
				<h2>Delivery Format</h2>
				<ul class="simple-list">
					<li>Holistic workshops, practical sessions, focus groups and therapeutic content</li>
					<li>Funded programme support, free to participants where sponsored</li>
					<li>In-person venue delivery with online access for catch-up</li>
					<li>Child-care / respite micro-grants available on request</li>
				</ul>
			</article>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<p class="section-kicker reveal">Partners & Funders</p>
			<div class="gallery" style="grid-template-columns: repeat(4, minmax(0, 1fr));">
				<img class="reveal" src="/media/wp/2025/06/bromley.png" alt="Bromley Council" />
				<img class="reveal" style="--delay: 0.05s" src="/media/wp/2025/06/yvhsc-300x156.png" alt="Your Voice in Health and Social Care" />
				<img class="reveal" style="--delay: 0.1s" src="/media/wp/2025/06/stubs.png" alt="STUBS Disability Services" />
				<img class="reveal" style="--delay: 0.15s" src="/media/wp/2025/06/mayoroflondon-300x53.jpg" alt="Mayor of London" />
			</div>
		</div>
	</section>
</Layout>

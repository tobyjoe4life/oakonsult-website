---
import Layout from "../../layouts/Layout.astro";
---

<Layout
	title="OAK Centre Prime | OAKonsult"
	description="Nigeria's first holistic disability centre, built in loving memory of Abigail."
	path="/programs/oak-centre-prime"
>
	<section class="section">
		<div class="container split">
			<div class="reveal">
				<p class="section-kicker">Program</p>
				<h1 class="section-title">OAK Centre Prime</h1>
				<p class="muted-copy" style="margin-top: 0.9rem;">
					Nigeria's first holistic disability centre, built in loving memory of Abigail.
				</p>
				<p class="muted-copy" style="margin-top: 0.6rem;">A home of healing, learning, and empowerment.</p>
				<div class="callout-actions" style="margin-top: 1.2rem;">
					<a class="button button-primary" href="/donate">Donate Now</a>
					<a class="button button-ghost" href="/programs-services">All Services</a>
				</div>
			</div>
			<img
				class="reveal"
				style="--delay: 0.12s"
				src="/media/wp/2025/04/4211940_1920x1080_f985cc-1.jpg"
				alt="OAK Centre Prime"
			/>
		</div>
	</section>

	<section class="section">
		<div class="container card-grid">
			<article class="card reveal">
				<h2>Abigail's Legacy</h2>
				<p>
					When medical mismanagement left Abigail Toyitan ventilator-dependent at 18 months,
					one family entered a world of wheelchairs and 24-hour care. Abigail defied every
					prognosis until October 2024, and her courage now inspires OAK Centre Prime.
				</p>
			</article>
			<article class="card reveal" style="--delay: 0.08s">
				<h2>What Is OAK Centre Prime?</h2>
				<p>
					A purpose-built holistic disability support centre designed to serve over 1,000
					children and young people every year, with safe residential accommodation for up to
					250 residents.
				</p>
				<ul class="simple-list" style="margin-top: 0.6rem;">
					<li>Inclusive education and specialist therapy</li>
					<li>Vocational and life-skills training</li>
					<li>Emotional, social and spiritual support</li>
					<li>Short-break and long-stay housing</li>
					<li>Community outreach and inclusion campaigns</li>
				</ul>
			</article>
			<article class="card reveal" style="--delay: 0.16s">
				<h2>Impact Targets</h2>
				<ul class="simple-list">
					<li>1,000+ children and young people served every year</li>
					<li>250 residential beds across respite and long-stay units</li>
					<li>400 local jobs during construction and 180 permanent roles on completion</li>
				</ul>
			</article>
		</div>
	</section>

	<section class="section">
		<div class="container callout reveal">
			<p class="section-kicker">Who We Serve</p>
			<p>
				Children and young people aged 0-25 with physical, intellectual or sensory
				disabilities, together with siblings and parent carers from Nigeria and the wider
				West African sub-region.
			</p>
			<p style="margin-top: 0.7rem;">
				Our solutions include medical and rehabilitation services, inclusive education,
				residential care, parent-carer support, faith-rooted counselling, and community
				advocacy.
			</p>
			<div class="callout-actions">
				<a class="button button-primary" href="/donate">Support OAK Centre Prime</a>
			</div>
		</div>
	</section>
</Layout>

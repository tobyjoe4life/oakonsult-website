---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Donation Confirmation | OAKonsult"
	description="Thank you for supporting OAKonsult."
	path="/donation-confirmation"
>
	<section class="section">
		<div class="container callout reveal">
			<p class="section-kicker">Thank You</p>
			<h1>Your donation was received</h1>
			<p>
				Thank you for your generosity. Your support helps OAKonsult provide practical care and
				inclusion-focused programmes for families raising children with disabilities.
			</p>
			<div class="callout-actions">
				<a class="button button-primary" href="/annual-reports-impact">View Our Impact</a>
				<a class="button button-ghost" href="/donate">Give Again</a>
			</div>
		</div>
	</section>
</Layout>

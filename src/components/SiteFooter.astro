---
import { brand, contact, navItems, programs, socialLinks } from "../data/site";
---

<footer class="site-footer">
	<div class="container footer-grid">
		<div>
			<a href="/" class="footer-logo" aria-label="Go to homepage">
				<img src="/media/logo-full.png" alt="OAKonsult logo" />
			</a>
			<p>{brand.description}</p>
			<div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
				{socialLinks.map((link) => (
					<a
						href={link.href}
						target="_blank"
						rel="noreferrer"
						aria-label={link.label}
						style="color: rgba(255,255,255,0.7); transition: color 0.12s;"
					>
						{link.label}
					</a>
				))}
			</div>
			<p style="margin-top: 0.75rem; font-size: var(--text-small); opacity: 0.6;">
				UK Charity Registration No. {contact.charityNumber}
			</p>
		</div>

		<div>
			<h3>Quick Links</h3>
			<ul class="footer-links">
				{navItems.filter(item => item.label !== "Home").map((item) => <li><a href={item.href}>{item.label}</a></li>)}
			</ul>
		</div>

		<div>
			<h3>Programs</h3>
			<ul class="footer-links">
				{programs.slice(0, 5).map((prog) => <li><a href={`/${prog.slug}`}>{prog.title}</a></li>)}
			</ul>
		</div>

		<div>
			<h3>Contact</h3>
			<p class="contact-line" style="margin-bottom: 0.25rem;">
				<a href={`mailto:${contact.email}`}>{contact.email}</a>
			</p>
			<p class="contact-line" style="margin-bottom: 0.75rem;">
				{contact.phones[0]}
			</p>
			<p style="font-size: var(--text-small);"><strong>United Kingdom</strong></p>
			<p style="font-size: var(--text-small); opacity: 0.8;">{contact.ukAddress.join(", ")}</p>
			<p style="font-size: var(--text-small); margin-top: 0.5rem;"><strong>Nigeria</strong></p>
			<p style="font-size: var(--text-small); opacity: 0.8;">{contact.ngAddress.join(", ")}</p>
		</div>
	</div>
	<div class="container footer-base">
		<div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;">
			<p>&copy; {new Date().getFullYear()} OAKonsult Disabilities Outreach. All rights reserved.</p>
			<div style="display: flex; gap: 1rem;">
				<a href="/privacy-policy" style="color: rgba(255,255,255,0.5);">Privacy Policy</a>
				<a href="/accessibility" style="color: rgba(255,255,255,0.5);">Accessibility</a>
			</div>
		</div>
	</div>
</footer>
